# AGORA Events - Environment Variables Example
# Copy this file to .env.local and fill in your values

# App Configuration
VITE_APP_NAME=AGORA Events
VITE_APP_URL=http://localhost:3000

# Default Language (en or fr)
VITE_DEFAULT_LANGUAGE=en

# API Configuration (for future backend integration)
# VITE_API_URL=http://localhost:3001/api

# Analytics (Optional)
# VITE_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SOCIAL_SHARING=true

# Note: Environment variables must start with VITE_ to be accessible in the browser
# For sensitive values, use .env.local (not committed to git)
